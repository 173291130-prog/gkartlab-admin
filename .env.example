# App
NODE_ENV=production
DATABASE_URL=file:/app/data/prod.db

# Initial admin account, used only when the database is empty.
ADMIN_INITIAL_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=change-this-password
ADMIN_INITIAL_NAME=Admin

# Public URL that the AI platform can access.
# Example: https://admin.example.com
AI_PUBLIC_BASE_URL=https://admin.example.com

# AI aggregation platform
AI_API_BASE_URL=https://api.lk888.ai
AI_API_KEY=
AI_IMAGE_ENDPOINT=/v1/media/generate
AI_IMAGE_MODEL=gpt-image-2
AI_STATUS_ENDPOINT=/v1/media/status?task_id=:id
AI_IMAGE_INPUT_FIELD=images
AI_IMAGE_INPUT_FORMAT=url
AI_IMAGE_INPUT_ARRAY=true
AI_IMAGE_SIZE=auto
AI_IMAGE_QUALITY=auto
AI_IMAGE_RESOLUTION=1K

# Storage provider. V1 uses local Docker volumes.
# Later this can be changed to oss/cos without changing business code.
STORAGE_PROVIDER=local
